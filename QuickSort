public class QuickSort {

	void quickSort(int numbers[], int start, int end)
	{
		if(start < end)
		{
			int pivot = numbers[end];
			int partitionIndex = start;
			
			for(int currentIndex = start; currentIndex < end; currentIndex++)
			{
				if(numbers[currentIndex] < pivot)
				{
					int temp = numbers[currentIndex];
					numbers[currentIndex] = numbers[partitionIndex];
					numbers[partitionIndex] = temp;
					partitionIndex++;
					
				}
			}
			int temp = numbers[partitionIndex];
			numbers[partitionIndex] = numbers[end];
			numbers[end] = temp;
			
			quickSort(numbers, start, partitionIndex-1);
			quickSort(numbers, partitionIndex+1, end);
		}
	}
}


//test1.java
public class Test1 {
public static void main(String[] args) {
	
	int numbers[] = {12,54,2,9,80};
	QuickSort s = new QuickSort();
	s.quickSort(numbers, 0, numbers.length-1);
	
	System.out.println("After Sorting:");
	for(int value : numbers)
	{
		System.out.print(value+ " ");
	}
  }
}

