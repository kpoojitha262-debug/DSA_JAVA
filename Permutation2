public class Permutation2 {

		static void findPermutation(String r, String result)
		{
			 
			if(r.length() == 0)
			{
				System.out.println(result);
				return;
			}
			for(int i = 0; i< r.length(); i++)
			{
				char ch = r.charAt(i);
				String remaining = r.substring(0,i) + r.substring(i+1);
				findPermutation(remaining , result+ch);
			}
		}
		public static void main(String[] args) {
			
			String r = "123";
			findPermutation(r," ");
		}
	}

